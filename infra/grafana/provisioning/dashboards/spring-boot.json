{
  "title": "Spring Boot Services",
  "uid": "spring-boot-services",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, application)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Requests / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\"}[1m])) by (uri, method, status)",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"$service\"}[1m])) by (le, uri)) * 1000",
          "legendFormat": "p95 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"$service\", status=~\"5..\"}[1m])) by (uri, status)",
          "legendFormat": "{{status}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"$service\", area=\"heap\"}",
          "legendFormat": "max {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 5,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"$service\"}",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"$service\"}",
          "legendFormat": "daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"$service\"}",
          "legendFormat": "peak"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "title": "GC Pause Time",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"$service\"}[1m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"$service\"}",
          "legendFormat": "process"
        },
        {
          "expr": "system_cpu_usage{application=\"$service\"}",
          "legendFormat": "system"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag{application=\"$service\"}",
          "legendFormat": "{{topic}} [{{partition}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 9,
      "title": "Kafka Records Consumed / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(kafka_consumer_fetch_manager_records_consumed_total{application=\"$service\"}[1m])",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 10,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"$service\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "green" } }
      }
    },
    {
      "id": 11,
      "title": "Open File Descriptors",
      "type": "stat",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_files_open_files{application=\"$service\"}",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 12,
      "title": "DB Connection Pool — Active",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hikaricp_connections_active{application=\"$service\"}",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_pending{application=\"$service\"}",
          "legendFormat": "pending"
        },
        {
          "expr": "hikaricp_connections_max{application=\"$service\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    }
  ]
}